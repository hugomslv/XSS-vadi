<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - XSS VADI</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <style>
    .exercise-stepper { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 1.5rem; }
    .stepper-item { padding: 4px 12px; border-radius: 999px; font-size: 0.75rem; font-weight: 600; background: var(--color-bg-secondary); color: var(--color-text-muted); border: 2px solid transparent; text-decoration: none; }
    .stepper-item.active { background: var(--color-warning-bg, #fff3cd); color: var(--color-warning, #856404); border-color: var(--color-warning, #ffc107); }
    .stepper-item.done { background: var(--color-success-bg, #d1e7dd); color: var(--color-success, #0f5132); }
    .hint-item { animation: fadeIn 0.3s ease; }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(-4px); } to { opacity: 1; transform: translateY(0); } }
    .choice-btn { width: 100%; text-align: left; padding: 12px 16px; border: 2px solid var(--color-border); background: var(--color-bg-secondary); }
    .choice-btn.selected { border-color: var(--color-primary); background: var(--color-primary-bg, #cfe2ff); }
    .choice-btn.correct { border-color: var(--color-success); background: var(--color-success-bg, #d1e7dd); }
    .choice-btn.wrong { border-color: var(--color-danger); background: var(--color-danger-bg, #f8d7da); }
    .simulated-page { border: 2px dashed var(--color-warning, #ffc107); border-radius: 8px; padding: 16px; background: var(--color-bg-secondary); }
    .url-bar { background: var(--color-bg); border: 1px solid var(--color-border); border-radius: 6px; padding: 6px 12px; font-family: 'JetBrains Mono', monospace; font-size: 0.8rem; color: var(--color-text-muted); margin-bottom: 12px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    #alertContainer { background: #1e1e2e; border: 1px solid #ffc107; border-radius: 8px; overflow: hidden; }
    .alert-intercept-header { background: #ffc107; color: #1e1e2e; font-size: 0.75rem; font-weight: 700; padding: 4px 12px; letter-spacing: 0.05em; }
    .alert-intercepted { padding: 8px 12px; font-size: 0.8rem; color: #e2e8f0; font-family: 'JetBrains Mono', monospace; word-break: break-all; border-top: 1px solid rgba(255,199,7,0.2); }
    .alert-intercepted + .alert-intercepted { border-top: 1px solid rgba(255,255,255,0.08); }
    .alert-intercept-label { color: #ffc107; font-weight: 700; display: block; margin-bottom: 2px; font-size: 0.7rem; }
    #validationResult { transition: all 0.3s ease; }
  </style>
</head>
<body>
  <% const currentPage = 'chapters'; %>
  <%- include('partials/navbar') %>

  <div class="alert alert-warning alert-banner">
    <span class="alert-icon">&#9888;</span>
    <div class="alert-content">
      <p class="alert-message"><strong>AVERTISSEMENT :</strong> Application VOLONTAIREMENT VULNERABLE - Usage pedagogique uniquement</p>
    </div>
  </div>

  <main class="container py-xl">
    <!-- Breadcrumb -->
    <nav class="breadcrumb">
      <span class="breadcrumb-item"><a href="/chapters">Chapitres</a></span>
      <span class="breadcrumb-separator">&#8250;</span>
      <span class="breadcrumb-item active"><%= chapter.title %></span>
    </nav>

    <!-- Stepper -->
    <div class="exercise-stepper">
      <% const allChaptersStepper = Array.from({length: totalChapters}, (_, i) => i); %>
      <% allChaptersStepper.forEach(i => { %>
        <a href="/chapter/chapter<%= i + 1 %>"
           class="stepper-item <%= i === currentIndex ? 'active' : '' %>">
          <%= i + 1 %>
        </a>
      <% }); %>
    </div>

    <!-- Title -->
    <div class="flex items-center justify-between mb-lg">
      <div>
        <div class="text-sm text-muted mb-sm">Exercice <%= currentIndex + 1 %> / <%= totalChapters %></div>
        <h1><%= chapter.title %></h1>
      </div>
    </div>

    <!-- Objective -->
    <% if (exercise) { %>
    <div class="chapter-objective mb-xl">
      <span class="chapter-objective-icon">&#127919;</span>
      <div>
        <strong class="text-primary">Objectif :</strong>
        <span class="text-secondary"><%= exercise.goal %></span>
      </div>
    </div>
    <% } %>

    <!-- Global admin comments -->
    <% if (globalComments.length > 0) { %>
    <div class="card card-primary mb-lg">
      <div class="card-header">
        <h4>&#128227; Annonces de l'administrateur</h4>
      </div>
      <div class="card-body">
        <% globalComments.forEach(comment => { %>
          <div class="alert alert-info mb-md">
            <div class="alert-content">
              <div class="flex justify-between items-center mb-sm">
                <strong>&#128100; Administrateur</strong>
                <span class="text-xs text-muted"><%= new Date(comment.timestamp).toLocaleString('fr-FR') %></span>
              </div>
              <div class="mt-sm"><%- comment.content %></div>
            </div>
          </div>
        <% }) %>
      </div>
    </div>
    <% } %>

    <!-- Theory card -->
    <div class="card card-primary mb-lg">
      <div class="card-header">
        <h4>&#128214; Cours</h4>
      </div>
      <div class="card-body">
        <%- chapter.content %>
      </div>
    </div>

    <% if (exercise) { %>

    <!-- Exercise card -->
    <div class="card card-warning mb-lg" id="exerciseCard">
      <div class="card-header">
        <h4>&#129514; Exercice</h4>
      </div>
      <div class="card-body">

        <!-- Instructions -->
        <div class="alert alert-info mb-lg">
          <span class="alert-icon">&#128203;</span>
          <div class="alert-content">
            <p class="alert-message"><%= exercise.instructions %></p>
          </div>
        </div>

        <!-- CHOICE type (exercise 7) -->
        <% if (exercise.validator.type === 'choice') { %>

          <div class="form-group mb-md">
            <label class="form-label">Payload XSS charge :</label>
            <div class="code-block"><pre><code><%- exercise.partialExample %></code></pre></div>
          </div>

          <div class="mb-md">
            <label class="form-label">Apercu du rendu selon la methode choisie :</label>
            <div id="choicePreview" class="card" style="min-height:60px">
              <div class="card-body text-muted text-sm">Selectionnez une methode ci-dessous...</div>
            </div>
          </div>

          <div class="mb-md" style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px">
            <button class="btn choice-btn" id="choice-a" onclick="selectChoice('a')">
              <strong>A.</strong> <code>innerHTML</code><br><span class="text-xs text-muted">Rendu HTML brut</span>
            </button>
            <button class="btn choice-btn" id="choice-b" onclick="selectChoice('b')">
              <strong>B.</strong> <code>textContent</code><br><span class="text-xs text-muted">Texte brut uniquement</span>
            </button>
            <button class="btn choice-btn" id="choice-c" onclick="selectChoice('c')">
              <strong>C.</strong> <code>innerHTML</code> + filtre<br><span class="text-xs text-muted">Blacklist de mots-cles</span>
            </button>
          </div>

          <div id="alertContainer" class="mb-md" style="display:none"></div>

        <!-- STORED XSS type (exercise 4) -->
        <% } else if (exercise.validator.type === 'storedXss') { %>

          <div class="form-group mb-md">
            <label for="exerciseInput" class="form-label">Payload a poster :</label>
            <textarea
              class="form-textarea font-mono"
              id="exerciseInput"
              rows="3"
              placeholder="Entrez votre payload XSS..."><%= exercise.partialExample %></textarea>
          </div>

          <div class="flex gap-md mb-lg" style="flex-wrap:wrap">
            <button class="btn btn-warning" onclick="addStoredPost()">&#128228; Poster dans les commentaires</button>
            <button class="btn" id="reloadBtn" onclick="simulateReload()" style="display:none">&#128260; Simuler rechargement</button>
          </div>

          <div id="simulatedCommentsCard" class="card mb-md" style="display:none">
            <div class="card-header">
              <h5>&#128172; Commentaires stockes (simulation)</h5>
            </div>
            <div class="card-body" id="simulatedComments"></div>
          </div>

          <div id="alertContainer" class="mb-md" style="display:none"></div>

        <!-- DOM XSS type (exercise 6) -->
        <% } else if (exercise.validator.type === 'domXss') { %>

          <div class="card mb-lg">
            <div class="card-header">
              <h5>&#127760; Page vulnerable simulee</h5>
            </div>
            <div class="card-body">
              <div class="form-group mb-md">
                <label class="form-label">Modifie la valeur du parametre <code>nom</code> :</label>
                <div class="flex gap-md items-center" style="flex-wrap:wrap">
                  <span class="font-mono text-sm text-muted" style="white-space:nowrap">?nom=</span>
                  <input type="text" class="form-input font-mono" id="domXssParam"
                    value="<%= exercise.partialExample %>"
                    placeholder="Entrez une valeur..."
                    oninput="updateDomXss()" style="flex:1;min-width:200px">
                </div>
                <div class="url-bar mt-sm" id="urlBar">http://vulnerable-site.com/page?nom=Visiteur</div>
              </div>

              <div class="simulated-page">
                <div class="text-xs text-muted mb-sm">&#128196; page.html — injection via <code>innerHTML</code></div>
                <p>Bienvenue, <strong><span id="domXssTitle">Visiteur</span></strong> !</p>
                <p class="text-sm text-muted">Cette page lit le parametre URL et l'affiche sans nettoyage.</p>
              </div>
            </div>
          </div>

          <div id="alertContainer" class="mb-md" style="display:none"></div>

        <!-- STANDARD types: domCheck, regex (exercises 1, 2, 3, 5) -->
        <% } else { %>

          <div class="form-group mb-md">
            <label for="exerciseInput" class="form-label">Votre payload :</label>
            <textarea
              class="form-textarea font-mono"
              id="exerciseInput"
              rows="3"
              placeholder="Entrez votre code HTML..."
              oninput="updatePreview()"><%= exercise.partialExample %></textarea>
          </div>

          <!-- Dual preview -->
          <div class="xss-comparison mb-md">
            <div class="xss-panel vulnerable">
              <div class="xss-panel-header">
                <span class="badge badge-danger">&#9888; UNSAFE</span>
                innerHTML
              </div>
              <div class="xss-panel-body" id="unsafePreview"></div>
            </div>
            <div class="xss-panel secure">
              <div class="xss-panel-header">
                <span class="badge badge-success">&#10003; SAFE</span>
                textContent
              </div>
              <div class="xss-panel-body" id="safePreview"></div>
            </div>
          </div>

          <div id="alertContainer" class="mb-md" style="display:none"></div>

        <% } %>

        <!-- Admin solution (shown immediately for teacher) -->
        <% if (isAdmin) { %>
        <div class="alert alert-success mb-md">
          <span class="alert-icon">&#128218;</span>
          <div class="alert-content">
            <p class="alert-title">Solution (mode enseignant)</p>
            <p class="alert-message"><code><%- exercise.solution %></code>
            <% if (exercise.solutionNote) { %> — <%= exercise.solutionNote %><% } %></p>
          </div>
        </div>
        <% } %>

        <!-- Action buttons -->
        <div class="flex gap-md mt-md" style="flex-wrap:wrap">
          <button class="btn btn-primary" onclick="validateExercise()" id="validateBtn">&#10003; Valider ma reponse</button>
          <button class="btn btn-sm" onclick="revealSolution()" id="showSolutionBtn">&#128161; Voir la solution</button>
        </div>

        <!-- Solution reveal (hidden) -->
        <div id="solutionBlock" class="alert alert-warning mt-md" style="display:none">
          <span class="alert-icon">&#128161;</span>
          <div class="alert-content">
            <p class="alert-title">Solution</p>
            <p class="alert-message"><code><%- exercise.solution %></code></p>
            <% if (exercise.solutionNote) { %>
              <p class="alert-message text-sm"><%= exercise.solutionNote %></p>
            <% } %>
          </div>
        </div>

      </div>
    </div>

    <!-- Hints card -->
    <div class="card mb-lg">
      <div class="card-header">
        <h4>&#128161; Indices progressifs</h4>
      </div>
      <div class="card-body">
        <div id="hintsList" class="mb-md"></div>
        <button class="btn btn-sm" id="hintBtn" onclick="showNextHint()">
          Reveler l'indice 1 / <%= exercise.hints.length %>
        </button>
      </div>
    </div>

    <!-- Validation result -->
    <div id="validationResult" class="mb-lg" style="display:none"></div>

    <!-- Explanation card (hidden until success) -->
    <div id="explanationCard" class="card card-success mb-lg" style="display:none">
      <div class="card-header">
        <h4>&#9989; Explication</h4>
      </div>
      <div class="card-body">
        <%- exercise.explanation %>
      </div>
    </div>

    <% } %>

    <!-- Navigation -->
    <div class="flex justify-between items-center mt-xl">
      <% const _prev = typeof prevChapter !== 'undefined' ? prevChapter : null; %>
      <% const _next = typeof nextChapter !== 'undefined' ? nextChapter : null; %>
      <% const _idx  = typeof currentIndex !== 'undefined' ? currentIndex : null; %>
      <% const _tot  = typeof totalChapters !== 'undefined' ? totalChapters : null; %>

      <% if (_prev) { %>
        <a href="/chapter/<%= _prev.id %>" class="btn">&#8592; <%= _prev.title.replace(/^Exercice \d+ : /, '') %></a>
      <% } else { %>
        <a href="/chapters" class="btn">&#8592; Liste des chapitres</a>
      <% } %>

      <% if (_idx !== null) { %>
        <span class="text-sm text-muted">Exercice <%= _idx + 1 %> / <%= _tot %></span>
      <% } %>

      <% if (_next) { %>
        <a href="/chapter/<%= _next.id %>" class="btn btn-primary"><%= _next.title.replace(/^Exercice \d+ : /, '') %> &#8594;</a>
      <% } else { %>
        <a href="/demo" class="btn btn-primary">Demo interactive &#8594;</a>
      <% } %>
    </div>

  </main>

  <%- include('partials/footer') %>

  <script src="/js/app.js"></script>
  <script>
    // ── Exercise data ──────────────────────────────────────────────
    const EXERCISE = <%- exercise ? JSON.stringify(exercise).replace(/<\//g, '<\\/') : 'null' %>;
    const IS_ADMIN = <%= isAdmin ? 'true' : 'false' %>;

    // ── State ──────────────────────────────────────────────────────
    let hintsShown = 0;
    let exerciseCompleted = false;
    let selectedChoice = null;
    let storedPosts = [];
    let reloadSimulated = false;
    const interceptedAlerts = [];

    // ── Alert interception ─────────────────────────────────────────
    window.alert = function(msg) {
      const message = String(msg);
      interceptedAlerts.push(message);
      const container = document.getElementById('alertContainer');
      if (container) {
        container.style.display = 'block';
        if (!container.querySelector('.alert-intercept-header')) {
          const header = document.createElement('div');
          header.className = 'alert-intercept-header';
          header.textContent = '🔔 ALERT() INTERCEPTE';
          container.prepend(header);
        }
        const div = document.createElement('div');
        div.className = 'alert-intercepted';
        div.innerHTML = '<span class="alert-intercept-label">alert() #' + interceptedAlerts.length + '</span>' + escapeHtml(message);
        container.appendChild(div);
      }
      // For domXss: mark that alert fired
      if (EXERCISE && EXERCISE.validator.type === 'domXss') {
        domXssAlertFired = true;
      }
    };

    function escapeHtml(str) {
      return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    // ── Standard preview (exercises 1, 2, 3, 5) ───────────────────
    function updatePreview() {
      if (!EXERCISE || EXERCISE.validator.type === 'choice' ||
          EXERCISE.validator.type === 'storedXss' || EXERCISE.validator.type === 'domXss') return;

      const input = document.getElementById('exerciseInput')?.value || '';
      const unsafePanel = document.getElementById('unsafePreview');
      const safePanel = document.getElementById('safePreview');

      if (unsafePanel) {
        unsafePanel.innerHTML = input;
        // Re-execute injected <script> tags to simulate real behavior
        unsafePanel.querySelectorAll('script').forEach(old => {
          const s = document.createElement('script');
          s.textContent = old.textContent;
          old.replaceWith(s);
        });
      }
      if (safePanel) {
        safePanel.textContent = input;
      }
    }

    // ── Stored XSS simulation ──────────────────────────────────────
    function addStoredPost() {
      const input = document.getElementById('exerciseInput')?.value || '';
      if (!input.trim()) return;
      storedPosts.push(input);
      renderStoredPosts();
      document.getElementById('simulatedCommentsCard').style.display = 'block';
      document.getElementById('reloadBtn').style.display = 'inline-flex';
    }

    function renderStoredPosts() {
      const container = document.getElementById('simulatedComments');
      if (!container) return;
      container.innerHTML = '';
      storedPosts.forEach(post => {
        const div = document.createElement('div');
        div.className = 'card mb-sm';
        div.innerHTML = '<div class="card-body"><div class="flex justify-between mb-sm"><span class="text-sm">&#128100; Utilisateur</span><span class="badge badge-unsafe">UNSAFE</span></div><div>' + post + '</div></div>';
        container.appendChild(div);
      });
    }

    function simulateReload() {
      reloadSimulated = true;
      renderStoredPosts();
      if (ToastManager) ToastManager.info('Rechargement simule — les payloads stockes se re-executent !', 3000);
    }

    // ── DOM XSS simulation ─────────────────────────────────────────
    let domXssAlertFired = false;

    function updateDomXss() {
      const param = document.getElementById('domXssParam')?.value || '';
      const titleEl = document.getElementById('domXssTitle');
      const urlBar = document.getElementById('urlBar');

      if (urlBar) urlBar.textContent = 'http://vulnerable-site.com/page?nom=' + param;
      if (titleEl) titleEl.innerHTML = param; // Intentionally vulnerable for demo
    }

    // ── Choice selection (exercise 7) ──────────────────────────────
    const PAYLOAD_CHOICE = '<img src=x onerror="alert(\'XSS\')">';

    function selectChoice(choice) {
      selectedChoice = choice;
      document.querySelectorAll('.choice-btn').forEach(b => b.classList.remove('selected'));
      document.getElementById('choice-' + choice).classList.add('selected');

      const preview = document.getElementById('choicePreview');
      const alertContainer = document.getElementById('alertContainer');
      if (alertContainer) alertContainer.style.display = 'none';
      if (alertContainer) alertContainer.innerHTML = '';

      if (preview) {
        if (choice === 'a') {
          preview.innerHTML = '<div class="card-body">' + PAYLOAD_CHOICE + '</div>';
          // Re-execute scripts
          preview.querySelectorAll('script').forEach(old => {
            const s = document.createElement('script');
            s.textContent = old.textContent;
            old.replaceWith(s);
          });
        } else if (choice === 'b') {
          preview.innerHTML = '<div class="card-body"></div>';
          preview.querySelector('.card-body').textContent = PAYLOAD_CHOICE;
        } else if (choice === 'c') {
          // Blacklist approach (easily bypassed)
          const filtered = PAYLOAD_CHOICE
            .replace(/onerror/gi, '')
            .replace(/alert/gi, '');
          preview.innerHTML = '<div class="card-body">' + filtered + '</div>';
        }
      }
    }

    // ── Validation ─────────────────────────────────────────────────
    function validateExercise() {
      if (!EXERCISE || exerciseCompleted) return;
      const validator = EXERCISE.validator;
      let success = false;

      if (validator.type === 'domCheck') {
        const input = document.getElementById('exerciseInput')?.value || '';
        const tmp = document.createElement('div');
        tmp.innerHTML = input;
        const el = tmp.querySelector(validator.tag);
        if (el) {
          if (validator.minTextLength) {
            success = el.textContent.trim().length >= validator.minTextLength;
          } else if (validator.attrs) {
            success = validator.attrs.every(a => el.hasAttribute(a));
          } else {
            success = true;
          }
        }

      } else if (validator.type === 'regex') {
        const input = document.getElementById('exerciseInput')?.value || '';
        const re = new RegExp(validator.pattern, 'i');
        success = re.test(input);

      } else if (validator.type === 'storedXss') {
        success = storedPosts.length > 0 && reloadSimulated;

      } else if (validator.type === 'domXss') {
        const param = document.getElementById('domXssParam')?.value || '';
        success = /(onerror|onclick|onload)/i.test(param) && /alert/i.test(param);

      } else if (validator.type === 'choice') {
        success = selectedChoice === validator.correctChoice;
      }

      if (success) {
        showSuccess();
      } else {
        showError();
      }
    }

    function showSuccess() {
      exerciseCompleted = true;
      const result = document.getElementById('validationResult');
      result.style.display = 'block';
      result.className = 'alert alert-success mb-lg';
      result.innerHTML = '<span class="alert-icon">&#9989;</span><div class="alert-content"><p class="alert-message"><strong>Bravo !</strong> Exercice reussi. Lisez l\'explication ci-dessous.</p></div>';
      document.getElementById('explanationCard').style.display = 'block';
      document.getElementById('validateBtn').disabled = true;
      document.getElementById('showSolutionBtn').style.display = 'none';
      document.getElementById('explanationCard').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }

    function showError() {
      const result = document.getElementById('validationResult');
      result.style.display = 'block';
      result.className = 'alert alert-danger mb-lg';
      result.innerHTML = '<span class="alert-icon">&#10060;</span><div class="alert-content"><p class="alert-message">Pas encore correct... Utilisez un indice ou verifiez la preview UNSAFE.</p></div>';
    }

    // ── Hints ──────────────────────────────────────────────────────
    function showNextHint() {
      if (!EXERCISE || hintsShown >= EXERCISE.hints.length) return;
      const container = document.getElementById('hintsList');
      const div = document.createElement('div');
      div.className = 'alert alert-info mb-sm hint-item';
      div.innerHTML = '<span class="alert-icon">&#128161;</span><div class="alert-content"><p class="alert-message"><strong>Indice ' + (hintsShown + 1) + ' :</strong> ' + EXERCISE.hints[hintsShown] + '</p></div>';
      container.appendChild(div);
      hintsShown++;
      const btn = document.getElementById('hintBtn');
      if (hintsShown >= EXERCISE.hints.length) {
        btn.disabled = true;
        btn.textContent = 'Tous les indices reveles';
      } else {
        btn.textContent = 'Reveler l\'indice ' + (hintsShown + 1) + ' / ' + EXERCISE.hints.length;
      }
    }

    // ── Solution reveal ────────────────────────────────────────────
    function revealSolution() {
      document.getElementById('solutionBlock').style.display = 'flex';
      document.getElementById('showSolutionBtn').style.display = 'none';
    }

    // ── Init ───────────────────────────────────────────────────────
    document.addEventListener('DOMContentLoaded', () => {
      if (!EXERCISE) return;

      // Initial preview for standard exercises
      if (EXERCISE.validator.type !== 'choice' &&
          EXERCISE.validator.type !== 'storedXss' &&
          EXERCISE.validator.type !== 'domXss') {
        updatePreview();
      }

      // Initial DOM XSS render
      if (EXERCISE.validator.type === 'domXss') {
        updateDomXss();
      }

      // Admin: auto-show explanation
      if (IS_ADMIN) {
        document.getElementById('explanationCard').style.display = 'block';
      }
    });
  </script>
</body>
</html>
